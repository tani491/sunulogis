generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String?
  role         String   @default("owner")
  phone        String?
  isActive     Boolean  @default(true)
  isSubscribed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  establishments       Establishment[]
  posts                BlogPost[]
  subscriptionRequests SubscriptionRequest[]

  @@index([role])
  @@index([isActive])
}

model SubscriptionRequest {
  id                 String   @id @default(cuid())
  userId             String
  amount             Int      @default(15000)
  status             String   @default("PENDING")
  transactionDetails String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Establishment {
  id             String    @id @default(cuid())
  ownerId        String
  name           String
  type           String    @default("auberge")
  description    String    @default("")
  city           String
  region         String    @default("")
  address        String    @default("")
  images         String    @default("[]")
  website        String?
  phone          String?
  isFeatured     Boolean   @default(false)
  isVerified     Boolean   @default(false)
  paymentPending Boolean   @default(false)
  boostExpiry    DateTime?
  viewsCount     Int       @default(0)
  clicksCount    Int       @default(0)
  isApproved     Boolean   @default(false)
  isSuspended    Boolean   @default(false)
  commission     Int       @default(0)
  paymentStatus  String    @default("en_attente")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms Room[]

  @@index([ownerId])
  @@index([type])
  @@index([city])
  @@index([isApproved])
  @@index([isFeatured])
  @@index([paymentStatus])
}

model Room {
  id              String   @id @default(cuid())
  establishmentId String
  name            String
  pricePerNight   Int
  capacity        Int      @default(1)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([establishmentId])
  @@index([isAvailable])
}

model Booking {
  id         String   @id @default(cuid())
  roomId     String
  guestName  String
  guestPhone String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([status])
  @@index([startDate])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @default("")
  content     String   @default("")
  coverImage  String?
  category    String   @default("general")
  isPublished Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@index([authorId])
}

model Subscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  consentStatus Boolean  @default(true)
  source        String   @default("footer")
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([source])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  source    String   @default("direct")
  medium    String?
  country   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([source])
  @@index([country])
  @@index([createdAt])
}
