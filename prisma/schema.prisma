generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?
  fullName  String?
  role      String   @default("owner") // "client", "owner", "admin"
  password  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  establishments Establishment[]
  posts          BlogPost[]
}

model Establishment {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  type        String   @default("auberge") // "auberge", "hotel", "appartement", "appartement_meuble", "lodge", "loft"
  description String   @default("")
  city        String
  region      String   @default("")
  address     String   @default("")
  images      String   @default("[]")
  website     String?
  phone       String?
  isApproved  Boolean  @default(false) // Admin must approve
  isSuspended Boolean  @default(false) // Admin can suspend
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       Profile  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms       Room[]
}

model Room {
  id              String   @id @default(cuid())
  establishmentId String
  name            String
  pricePerNight   Int
  capacity        Int      @default(1)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  bookings        Booking[]
}

model Booking {
  id         String   @id @default(cuid())
  roomId     String
  guestName  String
  guestPhone String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("pending") // "pending", "confirmed", "cancelled"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @default("")
  content     String   @default("")
  coverImage  String?
  category    String   @default("general")
  isPublished Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      Profile  @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
