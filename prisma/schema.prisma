generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model Profile {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?
  fullName  String?
  role      String   @default("owner") // "client", "owner", "admin"
  password  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isSubscribed Boolean @default(false)

  establishments Establishment[]
  posts          BlogPost[]

  @@index([role])
  @@index([isActive])
}

model Establishment {
  id            String   @id @default(cuid())
  ownerId       String
  name          String
  type          String   @default("auberge") // "auberge", "hotel", "appartement", "appartement_meuble", "lodge", "loft", "villa", "maison_a_vendre"
  description   String   @default("")
  city          String
  region        String   @default("")
  address       String   @default("")
  images        String   @default("[]")
  website       String?
  phone         String?
  isApproved    Boolean  @default(false)
  isSuspended   Boolean  @default(false)
  commission    Int      @default(0)
  paymentStatus String   @default("en_attente") // "en_attente", "paye"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms Room[]

  @@index([ownerId])
  @@index([type])
  @@index([city])
  @@index([region])
  @@index([isApproved])
  @@index([paymentStatus])
}

model Room {
  id              String   @id @default(cuid())
  establishmentId String
  name            String
  pricePerNight   Int
  capacity        Int      @default(1)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([establishmentId])
  @@index([isAvailable])
}

model Booking {
  id         String   @id @default(cuid())
  roomId     String
  guestName  String
  guestPhone String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("pending") // "pending", "confirmed", "cancelled"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([status])
  @@index([startDate])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @default("")
  content     String   @default("")
  coverImage  String?
  category    String   @default("general")
  isPublished Boolean  @default(false)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@index([authorId])
}

model Subscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  consentStatus Boolean  @default(true)
  source        String   @default("footer") // "footer", "blog", "landing"
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([source])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  source    String   @default("direct") // "direct", "search", "social", "referral"
  medium    String?  // "google", "facebook", "twitter", "instagram", "linkedin", "tiktok", etc.
  country   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([source])
  @@index([country])
  @@index([createdAt])
}
