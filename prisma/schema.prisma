generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?   // fullName
  password      String?
  role          String    @default("owner") // "client", "owner", "admin"
  phone         String?
  isActive      Boolean   @default(true)
  isSubscribed  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  establishments Establishment[]
  posts          BlogPost[]

  @@index([role])
  @@index([isActive])
}

model Establishment {
  id              String   @id @default(cuid())
  ownerId         String
  name            String
  type            String   @default("auberge")
  description     String   @default("")
  city            String
  region          String   @default("")
  address         String   @default("")
  images          String   @default("[]")
  website         String?
  phone           String?
  
  // --- SYSTÈME FREEMIUM (PRO) ---
  isFeatured      Boolean  @default(false)
  isVerified      Boolean  @default(false)
  paymentPending  Boolean  @default(false)
  boostExpiry     DateTime?
  viewsCount      Int      @default(0)
  clicksCount     Int      @default(0)

  isApproved      Boolean  @default(false)
  isSuspended     Boolean  @default(false)
  commission      Int      @default(0)
  paymentStatus   String   @default("en_attente")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms Room[]

  @@index([ownerId])
  @@index([type])
  @@index([city])
  @@index([isApproved])
}

model Room {
  id              String   @id @default(cuid())
  establishmentId String
  name            String
  pricePerNight   Int
  capacity        Int      @default(1)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([establishmentId])
}

model Booking {
  id         String   @id @default(cuid())
  roomId     String
  guestName  String
  guestPhone String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @default("")
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Garde tes modèles Subscriber, PageView si tu en as besoins